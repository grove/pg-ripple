# GraphRAG RDF Ontology for pg_ripple (v0.26.0)
#
# Namespace: https://graphrag.org/ns/
# Prefix:    gr:
#
# Defines the RDF vocabulary for Microsoft GraphRAG's knowledge model.
# Load into pg_ripple:
#   SELECT pg_ripple.load_turtle(pg_read_file('/path/to/graphrag_ontology.ttl'));
# Or via the example:
#   \i examples/graphrag_byog.sql

@prefix gr:   <https://graphrag.org/ns/> .
@prefix rdf:  <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl:  <http://www.w3.org/2002/07/owl#> .
@prefix xsd:  <http://www.w3.org/2001/XMLSchema#> .
@prefix sh:   <http://www.w3.org/ns/shacl#> .

# ── Ontology declaration ──────────────────────────────────────────────────────

<https://graphrag.org/ns/>
    a owl:Ontology ;
    rdfs:label "GraphRAG RDF Ontology" ;
    rdfs:comment "RDF vocabulary for Microsoft GraphRAG knowledge graph entities, relationships, and community structures." .

# ── Core Classes ──────────────────────────────────────────────────────────────

gr:Entity
    a owl:Class ;
    rdfs:label "Entity" ;
    rdfs:comment "A named entity extracted from source documents by GraphRAG. Corresponds to the GraphRAG entities table." .

gr:Relationship
    a owl:Class ;
    rdfs:label "Relationship" ;
    rdfs:comment "A directed relationship between two entities, extracted by GraphRAG. Corresponds to the GraphRAG relationships table." .

gr:TextUnit
    a owl:Class ;
    rdfs:label "Text Unit" ;
    rdfs:comment "A chunk of source text from which entities and relationships were extracted. Corresponds to the GraphRAG text_units table." .

gr:Community
    a owl:Class ;
    rdfs:label "Community" ;
    rdfs:comment "A thematic cluster of entities detected by GraphRAG's community detection algorithm." .

gr:CommunityReport
    a owl:Class ;
    rdfs:label "Community Report" ;
    rdfs:comment "An LLM-generated summary report for a community. Corresponds to the GraphRAG community_reports table." .

# ── Entity Properties ─────────────────────────────────────────────────────────

gr:title
    a owl:DatatypeProperty ;
    rdfs:domain gr:Entity ;
    rdfs:range xsd:string ;
    rdfs:label "title" ;
    rdfs:comment "Short display name for the entity (e.g. 'Alice', 'Acme Corp')." .

gr:type
    a owl:DatatypeProperty ;
    rdfs:domain gr:Entity ;
    rdfs:range xsd:string ;
    rdfs:label "type" ;
    rdfs:comment "Entity type category: one of 'person', 'organization', 'geo', 'event', 'concept'." .

gr:description
    a owl:DatatypeProperty ;
    rdfs:label "description" ;
    rdfs:comment "Free-text description of the entity or relationship, as generated by the LLM." .

gr:frequency
    a owl:DatatypeProperty ;
    rdfs:domain gr:Entity ;
    rdfs:range xsd:integer ;
    rdfs:label "frequency" ;
    rdfs:comment "Number of times the entity appears across all text units." .

gr:degree
    a owl:DatatypeProperty ;
    rdfs:domain gr:Entity ;
    rdfs:range xsd:integer ;
    rdfs:label "degree" ;
    rdfs:comment "Number of relationships the entity participates in (graph degree)." .

# ── Relationship Properties ───────────────────────────────────────────────────

gr:source
    a owl:ObjectProperty ;
    rdfs:domain gr:Relationship ;
    rdfs:range gr:Entity ;
    rdfs:label "source" ;
    rdfs:comment "Source entity of the relationship." .

gr:target
    a owl:ObjectProperty ;
    rdfs:domain gr:Relationship ;
    rdfs:range gr:Entity ;
    rdfs:label "target" ;
    rdfs:comment "Target entity of the relationship." .

gr:weight
    a owl:DatatypeProperty ;
    rdfs:domain gr:Relationship ;
    rdfs:range xsd:float ;
    rdfs:label "weight" ;
    rdfs:comment "Confidence/strength weight of the relationship, in the range [0.0, 1.0]." .

gr:combinedDegree
    a owl:DatatypeProperty ;
    rdfs:domain gr:Relationship ;
    rdfs:range xsd:integer ;
    rdfs:label "combined degree" ;
    rdfs:comment "Sum of degree(source) + degree(target). Used for ranking relationships." .

# ── Text Unit Properties ──────────────────────────────────────────────────────

gr:text
    a owl:DatatypeProperty ;
    rdfs:domain gr:TextUnit ;
    rdfs:range xsd:string ;
    rdfs:label "text" ;
    rdfs:comment "Raw text content of the text unit." .

gr:tokenCount
    a owl:DatatypeProperty ;
    rdfs:domain gr:TextUnit ;
    rdfs:range xsd:integer ;
    rdfs:label "token count" ;
    rdfs:comment "Number of LLM tokens in this text unit." .

gr:documentId
    a owl:DatatypeProperty ;
    rdfs:domain gr:TextUnit ;
    rdfs:range xsd:string ;
    rdfs:label "document ID" ;
    rdfs:comment "Identifier of the source document this text unit belongs to." .

gr:mentionsEntity
    a owl:ObjectProperty ;
    rdfs:domain gr:TextUnit ;
    rdfs:range gr:Entity ;
    rdfs:label "mentions entity" ;
    rdfs:comment "Entity mentioned in this text unit." .

gr:mentionsRelationship
    a owl:ObjectProperty ;
    rdfs:domain gr:TextUnit ;
    rdfs:range gr:Relationship ;
    rdfs:label "mentions relationship" ;
    rdfs:comment "Relationship mentioned in this text unit." .

# ── Community Properties ──────────────────────────────────────────────────────

gr:level
    a owl:DatatypeProperty ;
    rdfs:domain gr:Community ;
    rdfs:range xsd:integer ;
    rdfs:label "level" ;
    rdfs:comment "Hierarchical level of the community (0 = most granular, higher = broader)." .

gr:rank
    a owl:DatatypeProperty ;
    rdfs:label "rank" ;
    rdfs:comment "Importance rank within the community hierarchy." .

gr:summary
    a owl:DatatypeProperty ;
    rdfs:domain gr:CommunityReport ;
    rdfs:range xsd:string ;
    rdfs:label "summary" ;
    rdfs:comment "Short LLM-generated summary of the community." .

gr:fullContent
    a owl:DatatypeProperty ;
    rdfs:domain gr:CommunityReport ;
    rdfs:range xsd:string ;
    rdfs:label "full content" ;
    rdfs:comment "Full LLM-generated report for the community." .

gr:hasMember
    a owl:ObjectProperty ;
    rdfs:domain gr:Community ;
    rdfs:range gr:Entity ;
    rdfs:label "has member" ;
    rdfs:comment "Entity that is a member of this community." .

gr:parent
    a owl:ObjectProperty ;
    rdfs:domain gr:Community ;
    rdfs:range gr:Community ;
    rdfs:label "parent" ;
    rdfs:comment "Parent community in the hierarchical community structure." .

# ── Provenance Properties (for RDF-star metadata) ────────────────────────────

gr:confidence
    a owl:DatatypeProperty ;
    rdfs:range xsd:float ;
    rdfs:label "confidence" ;
    rdfs:comment "LLM confidence score for an extracted triple, in the range [0.0, 1.0]." .

gr:sourceTextUnit
    a owl:ObjectProperty ;
    rdfs:range gr:TextUnit ;
    rdfs:label "source text unit" ;
    rdfs:comment "Text unit from which this triple was extracted." .

gr:extractedBy
    a owl:DatatypeProperty ;
    rdfs:range xsd:string ;
    rdfs:label "extracted by" ;
    rdfs:comment "Model or system that extracted this triple (e.g. 'gpt-4o')." .

gr:extractedAt
    a owl:DatatypeProperty ;
    rdfs:range xsd:dateTime ;
    rdfs:label "extracted at" ;
    rdfs:comment "Timestamp when this triple was extracted." .

# ── Derived Relationship Classes (populated by Datalog enrichment) ────────────

gr:coworker
    a owl:SymmetricProperty ;
    rdfs:subPropertyOf owl:topObjectProperty ;
    rdfs:label "coworker" ;
    rdfs:comment "Both entities appear as source in relationships targeting the same organization. Derived by Datalog." .

gr:collaborates
    a owl:SymmetricProperty ;
    rdfs:subPropertyOf owl:topObjectProperty ;
    rdfs:label "collaborates" ;
    rdfs:comment "Both entities are mentioned in the same text unit. Derived by Datalog." .

gr:indirectReport
    a owl:TransitiveProperty ;
    rdfs:subPropertyOf owl:topObjectProperty ;
    rdfs:label "indirect report" ;
    rdfs:comment "Transitive management relationship. Derived by Datalog from gr:manages chains." .

gr:relatedOrg
    a owl:SymmetricProperty ;
    rdfs:subPropertyOf owl:topObjectProperty ;
    rdfs:label "related organization" ;
    rdfs:comment "Two organizations share at least two entity-level relationships. Derived by Datalog." .

gr:manages
    a owl:ObjectProperty ;
    rdfs:domain gr:Entity ;
    rdfs:range gr:Entity ;
    rdfs:label "manages" ;
    rdfs:comment "Direct management relationship between two entities." .
