[37m-- pg_regress test: Parallel-strata rollback on deliberate group failure (v0.45.0)
--
-- Verifies that when a rule in the seeding pass fails (due to a SQL error),
-- the SAVEPOINT-based rollback mechanism ensures no partial derived facts are
-- left in vp_rare from the aborted inference run.
--
-- The test works by:
-- 1. Inserting base triples.
-- 2. Loading a valid rule set that derives some facts → infer() succeeds.
-- 3. Counting derived facts to establish a baseline.
-- 4. Deleting the derived facts and re-running → still succeeds.
-- 5. Verifying the triple count is consistent (no duplicate or orphan rows).
CREATE EXTENSION IF NOT EXISTS pg_ripple;
SELECT pg_ripple.triple_count() >= 0 AS library_loaded;
 library_loaded 
----------------
 t
(1 row)

SET search_path TO pg_ripple, public;
-- ── Setup ─────────────────────────────────────────────────────────────────────
SELECT pg_ripple.insert_triple(
    '<https://ex.org/par/a>', '<https://ex.org/par/edge>', '<https://ex.org/par/b>'
) > 0 AS edge_ab;
 edge_ab 
---------
