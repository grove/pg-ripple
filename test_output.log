(1 row)

-- ── Part 1: Valid inference runs to completion ────────────────────────────────
SELECT pg_ripple.load_rules(
    '?x <https://ex.org/par/reach> ?y :- ?x <https://ex.org/par/edge> ?y . '
    '?x <https://ex.org/par/reach> ?z :- ?x <https://ex.org/par/reach> ?y, ?y <https://ex.org/par/edge> ?z .',
    'par_rollback_test'
) > 0 AS rules_loaded;
 rules_loaded 
