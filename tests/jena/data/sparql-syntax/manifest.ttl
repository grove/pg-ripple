# Embedded Jena-style SPARQL syntax conformance fixtures for pg_ripple CI.
#
# Positive tests: valid SPARQL 1.1 that must parse without error.
# Negative tests: invalid SPARQL that must fail to parse.
#
# All tests are self-contained (no database or data files required).
# The pg_ripple test harness prepends @base before parsing so relative IRIs
# (e.g. <pos01.sparql>) resolve to absolute file:// paths automatically.

@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix mf:  <http://www.w3.org/2001/sw/DataAccess/tests/test-manifest#> .
@prefix jt:  <http://jena.hpl.hp.com/2005/05/test-manifest-extra#> .

<>
    rdf:type mf:Manifest ;
    mf:entries (
        <#pos01> <#pos02> <#pos03> <#pos04> <#pos05>
        <#pos06> <#pos07> <#pos08> <#pos09> <#pos10>
        <#neg01> <#neg02> <#neg03> <#neg04> <#neg05>
    ) .

# ── Positive syntax tests ─────────────────────────────────────────────────────

<#pos01>
    rdf:type  jt:PositiveSyntaxTest ;
    mf:name   "pos01: basic SELECT" ;
    mf:action <pos01.sparql> .

<#pos02>
    rdf:type  jt:PositiveSyntaxTest ;
    mf:name   "pos02: SELECT with FILTER isIRI" ;
    mf:action <pos02.sparql> .

<#pos03>
    rdf:type  jt:PositiveSyntaxTest ;
    mf:name   "pos03: SELECT with GROUP BY and HAVING" ;
    mf:action <pos03.sparql> .

<#pos04>
    rdf:type  jt:PositiveSyntaxTest ;
    mf:name   "pos04: SELECT with OPTIONAL" ;
    mf:action <pos04.sparql> .

<#pos05>
    rdf:type  jt:PositiveSyntaxTest ;
    mf:name   "pos05: SELECT with UNION" ;
    mf:action <pos05.sparql> .

<#pos06>
    rdf:type  jt:PositiveSyntaxTest ;
    mf:name   "pos06: SELECT with BIND" ;
    mf:action <pos06.sparql> .

<#pos07>
    rdf:type  jt:PositiveSyntaxTest ;
    mf:name   "pos07: SELECT with VALUES" ;
    mf:action <pos07.sparql> .

<#pos08>
    rdf:type  jt:PositiveSyntaxTest ;
    mf:name   "pos08: SELECT with subquery" ;
    mf:action <pos08.sparql> .

<#pos09>
    rdf:type  jt:PositiveSyntaxTest ;
    mf:name   "pos09: ASK query" ;
    mf:action <pos09.sparql> .

<#pos10>
    rdf:type  jt:PositiveSyntaxTest ;
    mf:name   "pos10: CONSTRUCT query" ;
    mf:action <pos10.sparql> .

# ── Negative syntax tests ─────────────────────────────────────────────────────

<#neg01>
    rdf:type  jt:NegativeSyntaxTest ;
    mf:name   "neg01: missing closing brace" ;
    mf:action <neg01.sparql> .

<#neg02>
    rdf:type  jt:NegativeSyntaxTest ;
    mf:name   "neg02: double-dollar variable (invalid)" ;
    mf:action <neg02.sparql> .

<#neg03>
    rdf:type  jt:NegativeSyntaxTest ;
    mf:name   "neg03: unknown query form keyword" ;
    mf:action <neg03.sparql> .

<#neg04>
    rdf:type  jt:NegativeSyntaxTest ;
    mf:name   "neg04: IRI with unencoded space" ;
    mf:action <neg04.sparql> .

<#neg05>
    rdf:type  jt:NegativeSyntaxTest ;
    mf:name   "neg05: unclosed string literal" ;
    mf:action <neg05.sparql> .
