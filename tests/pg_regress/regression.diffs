diff -U3 /Users/geir.gronmo/projects/pg_ripple/tests/pg_regress/expected/bsbm.out /Users/geir.gronmo/projects/pg_ripple/tests/pg_regress/results/bsbm.out
--- /Users/geir.gronmo/projects/pg_ripple/tests/pg_regress/expected/bsbm.out	2026-04-15 15:59:00
+++ /Users/geir.gronmo/projects/pg_ripple/tests/pg_regress/results/bsbm.out	2026-04-15 17:18:58
