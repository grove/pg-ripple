# LUBM Q11: Sub-organizations of Department0/University0.
# Tests: ub:subOrganizationOf inverse lookup; exercises domain/range inference.
# Expected result count (univ1 fixture): 1
PREFIX rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
PREFIX ub:  <http://www.lehigh.edu/~zhp2/2004/0401/univ-bench.owl#>
SELECT ?X WHERE {
  ?X ub:subOrganizationOf <http://www.Department0.University0.edu>
}
