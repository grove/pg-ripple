# LUBM Q8: Students in Department0/University0 with email address.
# Tests: ub:Student + ub:emailAddress + ub:memberOf + ub:subOrganizationOf chain.
# Expected result count (univ1 fixture): 12
PREFIX rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
PREFIX ub:  <http://www.lehigh.edu/~zhp2/2004/0401/univ-bench.owl#>
SELECT ?X ?Y ?Z WHERE {
  ?X rdf:type ub:Student .
  ?X ub:emailAddress ?Y .
  ?X ub:memberOf ?Z .
  ?Z ub:subOrganizationOf <http://www.University0.edu>
}
