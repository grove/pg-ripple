# LUBM Q10: Graduate students who are members of ResearchGroup0.
# Tests: ub:memberOf with a research group target.
# Expected result count (univ1 fixture): 3
PREFIX rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
PREFIX ub:  <http://www.lehigh.edu/~zhp2/2004/0401/univ-bench.owl#>
SELECT ?X WHERE {
  ?X rdf:type ub:GraduateStudent .
  ?X ub:memberOf <http://www.Department0.University0.edu/ResearchGroup0>
}
