# LUBM Q6: All students (graduate and undergraduate).
# Tests: ub:Student superclass reasoning (includes both GraduateStudent and UndergraduateStudent).
# Expected result count (univ1 fixture): 12
PREFIX rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
PREFIX ub:  <http://www.lehigh.edu/~zhp2/2004/0401/univ-bench.owl#>
SELECT ?X WHERE {
  ?X rdf:type ub:Student
}
