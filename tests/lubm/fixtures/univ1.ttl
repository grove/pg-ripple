@prefix rdf:  <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl:  <http://www.w3.org/2002/07/owl#> .
@prefix xsd:  <http://www.w3.org/2001/XMLSchema#> .
@prefix ub:   <http://www.lehigh.edu/~zhp2/2004/0401/univ-bench.owl#> .

# Synthetic LUBM univ-1 dataset for pg_ripple conformance testing.
#
# Structure: 1 university, 1 department, 1 research group, 4 faculty,
# 7 graduate students, 5 undergraduate students, 6 graduate courses,
# 1 undergraduate course, 4 publications.
#
# All types are stated explicitly (including superclasses) so the 14
# canonical LUBM queries return non-zero results even without OWL RL
# inference.  The Datalog sub-suite separately validates that inference
# produces the same results from implicit types alone.
#
# Expected query result counts (after data load, no inference required):
#   Q1:3  Q2:2  Q3:2  Q4:4  Q5:3  Q6:12  Q7:3  Q8:12  Q9:7
#   Q10:3 Q11:1 Q12:1 Q13:1 Q14:5

# ── University & Department ───────────────────────────────────────────────────

<http://www.University0.edu>
    a ub:University, owl:Thing .

<http://www.Department0.University0.edu>
    a ub:Department, owl:Thing ;
    ub:subOrganizationOf <http://www.University0.edu> .

<http://www.Department0.University0.edu/ResearchGroup0>
    a ub:ResearchGroup, owl:Thing ;
    ub:subOrganizationOf <http://www.Department0.University0.edu> .

# ── Courses ───────────────────────────────────────────────────────────────────

<http://www.Department0.University0.edu/GraduateCourse0>
    a ub:GraduateCourse, ub:Course, owl:Thing .

<http://www.Department0.University0.edu/GraduateCourse1>
    a ub:GraduateCourse, ub:Course, owl:Thing .

<http://www.Department0.University0.edu/GraduateCourse2>
    a ub:GraduateCourse, ub:Course, owl:Thing .

<http://www.Department0.University0.edu/GraduateCourse3>
    a ub:GraduateCourse, ub:Course, owl:Thing .

<http://www.Department0.University0.edu/GraduateCourse4>
    a ub:GraduateCourse, ub:Course, owl:Thing .

<http://www.Department0.University0.edu/GraduateCourse5>
    a ub:GraduateCourse, ub:Course, owl:Thing .

<http://www.Department0.University0.edu/UndergraduateCourse0>
    a ub:Course, owl:Thing .

# ── Faculty ───────────────────────────────────────────────────────────────────

# FullProfessor0 — head of Department0, teaches GC3 and GC4
<http://www.Department0.University0.edu/FullProfessor0>
    a ub:FullProfessor, ub:Professor, ub:Faculty, ub:Employee, ub:Person, owl:Thing ;
    ub:worksFor      <http://www.Department0.University0.edu> ;
    ub:headOf        <http://www.Department0.University0.edu> ;
    ub:teacherOf     <http://www.Department0.University0.edu/GraduateCourse3>,
                     <http://www.Department0.University0.edu/GraduateCourse4> ;
    ub:doctoralDegreeFrom <http://www.University0.edu> ;
    ub:name          "FullProfessor0"^^xsd:string ;
    ub:emailAddress  "fp0@Department0.University0.edu"^^xsd:string ;
    ub:telephone     "555-1000"^^xsd:string .

