    ub:teacherOf     <http://www.Department0.University0.edu/GraduateCourse0>,
                     <http://www.Department0.University0.edu/GraduateCourse1>,
                     <http://www.Department0.University0.edu/UndergraduateCourse0> ;
    ub:teachingAssistantOf <http://www.Department0.University0.edu/GraduateCourse3> ;
