    ub:teacherOf     <http://www.Department0.University0.edu/GraduateCourse5> ;
    ub:name          "AssociateProfessor0"^^xsd:string ;
    ub:emailAddress  "acp0@Department0.University0.edu"^^xsd:string ;
    ub:telephone     "555-1001"^^xsd:string .

